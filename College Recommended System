.nb-val{font-size:.72rem;font-weight:700;color:var(--accent2);width:40px;text-align:right;flex-shrink:0;}

/* COMPARE */
.cmp-pg{padding:1.25rem 1.25rem;max-width:1180px;margin:0 auto;}
