.cmpf.vis{opacity:1;pointer-events:auto;}
.cmpf span{font-size:.8rem;color:var(--text2);}
.cmpf strong{color:var(--teal);}
.empty-s{text-align:center;padding:3rem 2rem;color:var(--text3);}
.empty-s .ei{font-size:2.2rem;opacity:.22;margin-bottom:.65rem;}

