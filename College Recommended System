function fmtBot(text){
  return text
    .replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>')
    .replace(/\*(.*?)\*/g,'<em>$1</em>')
    .replace(/^(\d+)\.\s+/gm,'<br><strong style="color:var(--accent2)">$1.</strong> ')
    .replace(/^•\s+(.+)/gm,'<br>• $1')
    .replace(/\n\n+/g,'<br><br>')
    .replace(/\n/g,'<br>')
    .replace(/^<br>/,'');
}

