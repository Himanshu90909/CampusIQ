const HINTS={
  JEE_Advanced:'Enter AIR (All India Rank). e.g. 500',
  JEE_Main:'Enter AIR. e.g. 8000',
  CAT:'Enter percentile. e.g. 98.5',
  NEET:'Enter AIR. e.g. 1200',
  GATE:'Enter score (0–100). e.g. 68',
  BITSAT:'Enter total score (0–390). e.g. 335',
  Board_Marks:'Enter percentage (%). e.g. 96.5',
  CLAT:'Enter AIR. e.g. 250',
  KVPY:'Enter AIR/band. e.g. 300',
};
function updateHint(){
  const e=document.getElementById('pExam').value;
  const el=document.getElementById('scoreHint');
  if(el) el.textContent=HINTS[e]||'';
}

const CAT_MULT={General:1,OBC:2.8,SC:7.5,ST:12,EWS:2};

function normScore(exam,raw,cat){
  const s=parseFloat(String(raw).replace(/[^0-9.]/g,''));
  if(isNaN(s)) return null;
  const m=CAT_MULT[cat]||1;
  if(['JEE_Advanced','JEE_Main','NEET','CLAT'].includes(exam)) return {type:'rank',v:s/m};
  if(exam==='CAT') return {type:'pctile',v:Math.min(100,s+(m-1)*2)};
  if(exam==='BITSAT') return {type:'score_hi',v:s+(m-1)*8};
  if(exam==='GATE') return {type:'score_hi',v:s};
  if(exam==='Board_Marks') return {type:'score_hi',v:Math.min(100,s+(m-1)*1.5)};
  if(exam==='KVPY') return {type:'rank',v:s/m};
  return {type:'score_hi',v:s};
}

function calcChance(c,exam,ns,cat){
  const co=c.cutoffs;
  if(!co||!co[exam]) return null;
  const cut=co[exam];
  const cv=cut[cat]||cut['General'];
  if(cv===undefined||cv===null||typeof cv==='string') return null;

  let pct=0;
  if(ns.type==='rank'){
    const r=cv/ns.v;
    pct=r>=2.5?95:r>=1.8?85:r>=1.2?72:r>=1.0?58:r>=.75?40:r>=.5?22:r>=.3?10:4;
  } else if(ns.type==='pctile'){
    const d=ns.v-cv;
    pct=d>=2?92:d>=.8?80:d>=0?65:d>=-1.5?45:d>=-3?25:d>=-5?12:4;
  } else {
    const r=ns.v/cv;
    pct=r>=1.15?92:r>=1.06?80:r>=1.0?67:r>=.93?50:r>=.85?30:r>=.75?14:4;
  }
  // NIRF quality bonus
  const nirfBonus=(c.nirfScore/100)*4;
  return Math.max(3,Math.min(97,Math.round(pct+nirfBonus-2)));
}

function runPred(){
  const exam=document.getElementById('pExam').value;
  const raw=document.getElementById('pScore').value.trim();
  const cat=document.getElementById('pCat').value;
  const state=document.getElementById('pState').value;
  const stream=document.getElementById('pStream2').value;
  if(!raw){toast('Enter your score / rank','inf');return;}
  const ns=normScore(exam,raw,cat);
  if(!ns){toast('Invalid score','inf');return;}

  const res=[];
  DB.forEach(c=>{
    if(state&&c.state!==state) return;
    if(stream&&c.stream!==stream&&!c.stream.toLowerCase().includes(stream.toLowerCase())) return;
    const pct=calcChance(c,exam,ns,cat);
    if(pct===null) return;
    res.push({c,pct,g:pct>=65?'h':pct>=38?'m':'l'});
  });
  res.sort((a,b)=>b.pct-a.pct);

  const el=document.getElementById('predOut');
  if(!res.length){
    el.innerHTML=`<div class="empty-s"><div class="ei">🔍</div><p>No matches for ${exam} in this combination. Try removing state/stream filter.</p></div>`;
    return;
  }
  const rankSrc=r=>r.c.source==='nirf2025college'?`NIRF 2025 College #${r.c.nirf2025college}`:`NIRF 2020 #${r.c.nirf2020}`;
  el.innerHTML=`
    <div class="pred-res-hd">
      <h3>${exam.replace(/_/g,' ')} — ${raw} (${cat})</h3>
      <span class="mtag">${res.length} matches</span>
    </div>
    <div class="pred-cards">
    ${res.slice(0,14).map(r=>{
      const [g1,g2]=r.c.grad,t=r.c.abbr||'';
      const fs=t.length<=3?'.82rem':t.length<=4?'.72rem':'.6rem';
      return `<div class="pc" onclick="openDet(${r.c.id})">
        <div class="pc-l">
          <div class="pc-logo" style="background:linear-gradient(145deg,${g1},${g2});font-size:${fs}">${escH(t)}</div>
          <div>
            <div class="pc-name">${escH(r.c.name)}</div>
            <div class="pc-meta">${r.c.state} · ${rankSrc(r)} · ${fmtSal(r.c)} avg</div>
            <div class="pc-meter"><div class="pc-mf" style="width:${r.pct}%"></div></div>
          </div>
        </div>
        <div class="pc-r">
          <div class="pc-pct">
            <div class="pc-pct-n" style="color:${r.g==='h'?'var(--green)':r.g==='m'?'var(--gold2)':'var(--coral)'}">${r.pct}%</div>
            <div class="pc-pct-l">Chance</div>
          </div>
          <span class="chance ch-${r.g}">${r.g==='h'?'✅ High':r.g==='m'?'⚡ Med':'🔴 Low'}</span>
        </div>
      </div>`;
    }).join('')}
    </div>`;
}

