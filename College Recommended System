.cmp-pg>p{color:var(--text2);font-size:.85rem;margin-bottom:1.25rem;}
.cmp-slots{display:flex;gap:.9rem;overflow-x:auto;padding-bottom:.75rem;}
.cmp-slot{flex:1;min-width:200px;background:var(--card);border:1px solid var(--border);border-radius:var(--r2);overflow:hidden;}
.cmp-slot.empty{border-style:dashed;display:flex;align-items:center;justify-content:center;min-height:340px;}
.cmp-h{padding:1rem;border-bottom:1px solid var(--border);}
.cmp-attr{padding:.65rem 1rem;border-bottom:1px solid var(--border);}
.cmp-attr:last-child{border-bottom:none;}
.cmp-k{font-size:.6rem;text-transform:uppercase;letter-spacing:.07em;color:var(--text3);margin-bottom:.15rem;font-weight:700;}
.cmp-v{font-size:.85rem;font-weight:600;}
.cmp-best{color:var(--green)!important;}

/* STATES */
.toast{position:fixed;bottom:1.5rem;right:1.5rem;background:var(--card2);border:1px solid var(--border2);
  border-radius:9px;padding:.72rem 1rem;font-size:.82rem;z-index:400;transform:translateY(80px);
  opacity:0;transition:all .3s;pointer-events:none;max-width:250px;line-height:1.4;}
.toast.show{transform:translateY(0);opacity:1;}
.toast.ok{border-left:3px solid var(--green);}
.toast.inf{border-left:3px solid var(--accent);}
.cmpf{position:fixed;bottom:1.1rem;left:50%;transform:translateX(-50%);background:var(--bg2);
  border:1px solid var(--border2);border-radius:999px;padding:.5rem 1.1rem;
