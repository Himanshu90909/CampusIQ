function detectIntent(txt){
  for(const i of INTENTS) if(i.p.some(p=>p.test(txt))) return i.id;
  return 'general';
}

function extractEntities(txt){
  const t=txt.toLowerCase(),ent={};
  const states=['tamil nadu','delhi','maharashtra','karnataka','kerala','west bengal','punjab','rajasthan','telangana','uttar pradesh','gujarat','odisha','assam','bihar','jharkhand','madhya pradesh'];
  states.forEach(s=>{if(t.includes(s)) ent.state=s.split(' ').map(w=>w[0].toUpperCase()+w.slice(1)).join(' ');});

  if(/\biits?\b/i.test(txt)||/indian institute of technology/i.test(txt)) ent.instType='IIT';
  if(/\bnits?\b/i.test(txt)||/national institute of technology/i.test(txt)) ent.instType='NIT';
  if(/\biims?\b/i.test(txt)||/indian institute of management/i.test(txt)) ent.instType='IIM';
  if(/\biisc\b/i.test(txt)||/indian institute of science\b/i.test(txt)) ent.instType='IISc';
  if(/\biiser\b/i.test(txt)) ent.instType='IISER';

  if(/cse|computer science|cs\b|coding|software|ai\b|machine learning|\bengineering\b/i.test(txt)) ent.stream='Engineering';
  if(/mba|management|business|finance/i.test(txt)) ent.stream='Management';
  if(/medical|mbbs|doctor|neet/i.test(txt)) ent.stream='Medical';
  if(/law|legal|clat/i.test(txt)) ent.stream='Law';
  if(/science|research|physics|chemistry|biology/i.test(txt)) ent.stream='Sciences & Arts';

  const named=[];
  const queryWords=t.split(/\s+/);
  DB.forEach(c=>{
    const nl=c.name.toLowerCase(),al=(c.abbr||'').toLowerCase();
    // 1. Abbr word-boundary match (>=3 chars)
    const abbrMatch=al.length>=3 && new RegExp('\\b'+al+'\\b','i').test(t);
    // 2. Key words from name: at least 2 meaningful words from name appear in query
    const nameKW=nl.split(' ').filter(w=>w.length>3&&!['institute','technology','national','indian','university','college'].includes(w));
    const nameMatch=nameKW.length>=1 && nameKW.slice(0,2).filter(w=>t.includes(w)).length>=Math.min(2,nameKW.length);
    // 3. Common short-forms
    const shorts={'iit bombay':'bombay','iit delhi':'delhi','iit madras':'madras','iit kharagpur':'kharagpur','iit kanpur':'kanpur','iit roorkee':'roorkee','iit guwahati':'guwahati','iit hyderabad':'hyderabad','iisc bangalore':'bengaluru','nit trichy':'tiruchirappalli','nit warangal':'warangal','nit calicut':'calicut','jadavpur':'jadavpur','bits pilani':'pilani','jnu':'jawaharlal nehru','bhu':'banaras'};
    let shortMatch=false;
    for(const [sf,key] of Object.entries(shorts)){if(t.includes(sf)&&nl.includes(key))shortMatch=true;}
    if(abbrMatch||nameMatch||shortMatch) named.push(c);
  });
  if(named.length) ent.named=[...new Map(named.map(x=>[x.id,x])).values()];

  const nm=txt.match(/(?:rank|rank no|rank #)\s*(\d+)|(\d+)\s*(?:rank|air)|(\d+(?:\.\d+)?)\s*percentile|percentile\s*(\d+(?:\.\d+)?)/i);
  if(nm) ent.num=parseFloat(nm.slice(1).find(x=>x!==undefined));

  return ent;
}

function queryDB2(filters){
  let r=[...DB];
  if(filters.state) r=r.filter(c=>c.state.toLowerCase()===filters.state.toLowerCase());
  if(filters.type) r=r.filter(c=>c.type===filters.type);
  if(filters.stream) r=r.filter(c=>c.stream===filters.stream||c.stream.toLowerCase().includes(filters.stream.toLowerCase()));
  if(filters.source) r=r.filter(c=>c.source===filters.source);
  if(filters.maxFees) r=r.filter(c=>c.fees<=filters.maxFees);
  r.sort((a,b)=>b.nirfScore-a.nirfScore);
  if(filters.limit) r=r.slice(0,filters.limit);
  return r;
}

