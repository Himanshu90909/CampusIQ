<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CampusIQ India — NIRF Rankings AI Advisor</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#07090f;--bg2:#0d1018;--bg3:#141820;--card:#111520;--card2:#181e2c;
  --border:rgba(148,163,255,0.09);--border2:rgba(148,163,255,0.18);
  --accent:#6c63ff;--accent2:#a8a3ff;--accent3:#d4d2ff;
  --gold:#f5c842;--gold2:#ffd95c;--teal:#22d3b8;--coral:#ff6b6b;
  --green:#22c55e;--violet:#c084fc;
  --text:#eef0ff;--text2:#8892b8;--text3:#3d4668;
  --r:12px;--r2:18px;
  --font-d:'Syne',sans-serif;--font-b:'DM Sans',sans-serif;
  --glow:0 0 50px rgba(108,99,255,0.1);
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--text);font-family:var(--font-b);overflow-x:hidden;min-height:100vh;}
body::before{content:'';position:fixed;inset:0;z-index:0;
  background-image:linear-gradient(rgba(108,99,255,0.025) 1px,transparent 1px),linear-gradient(90deg,rgba(108,99,255,0.025) 1px,transparent 1px);
  background-size:44px 44px;mask-image:radial-gradient(ellipse 80% 50% at 50% 0%,black 40%,transparent 100%);pointer-events:none;}
body::after{content:'';position:fixed;inset:0;z-index:0;
  background:radial-gradient(ellipse 50% 40% at 75% 20%,rgba(108,99,255,0.06) 0%,transparent 60%),
             radial-gradient(ellipse 40% 30% at 25% 75%,rgba(34,211,184,0.04) 0%,transparent 60%);pointer-events:none;}
::-webkit-scrollbar{width:4px;}
::-webkit-scrollbar-track{background:var(--bg2);}
::-webkit-scrollbar-thumb{background:var(--accent);border-radius:2px;}

nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(7,9,15,0.9);backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);height:58px;padding:0 1.25rem;display:flex;align-items:center;gap:1.25rem;}
.logo{font-family:var(--font-d);font-size:1.25rem;font-weight:800;color:var(--text);cursor:pointer;
  letter-spacing:-0.03em;display:flex;align-items:center;gap:0.3rem;flex-shrink:0;}
.logo .orb{width:24px;height:24px;border-radius:7px;background:linear-gradient(135deg,var(--accent),var(--teal));
  display:flex;align-items:center;justify-content:center;font-size:0.75rem;}
.logo em{color:var(--accent2);font-style:normal;}
.nav-tabs{display:flex;gap:2px;flex:1;overflow-x:auto;}
.nav-tab{padding:0.3rem 0.8rem;border-radius:7px;font-size:0.8rem;font-weight:500;color:var(--text2);
  border:none;background:none;cursor:pointer;font-family:var(--font-b);transition:all .18s;white-space:nowrap;}
.nav-tab:hover{background:var(--bg3);color:var(--text);}
.nav-tab.active{background:rgba(108,99,255,0.15);color:var(--accent2);}
.nav-badge{font-size:0.58rem;background:var(--accent);color:#fff;border-radius:4px;padding:0.1rem 0.35rem;margin-left:0.3rem;font-weight:700;}

.btn{padding:0.4rem 0.95rem;border-radius:8px;font-size:0.8rem;font-weight:600;cursor:pointer;font-family:var(--font-b);transition:all .18s;border:none;}
.btn-ghost{background:transparent;color:var(--text2);border:1px solid var(--border2);}
.btn-ghost:hover{background:var(--bg3);color:var(--text);}
.btn-pri{background:linear-gradient(135deg,var(--accent),#8b83ff);color:#fff;box-shadow:0 4px 14px rgba(108,99,255,0.28);}
.btn-pri:hover{transform:translateY(-1px);box-shadow:0 6px 20px rgba(108,99,255,0.38);}
.btn-sm{padding:0.25rem 0.65rem;font-size:0.73rem;}
.btn-tl{background:rgba(34,211,184,0.1);color:var(--teal);border:1px solid rgba(34,211,184,0.28);}
.btn-tl:hover{background:rgba(34,211,184,0.18);}

.page{display:none;padding-top:58px;min-height:100vh;position:relative;z-index:1;}
.page.active{display:block;}

/* HOME */
.hero{padding:3.5rem 1.5rem 2rem;max-width:820px;margin:0 auto;text-align:center;}
.hero-badge{display:inline-flex;align-items:center;gap:0.45rem;background:rgba(108,99,255,0.1);
  border:1px solid rgba(108,99,255,0.25);border-radius:999px;padding:0.3rem 0.9rem;font-size:0.73rem;
  color:var(--accent3);margin-bottom:1.5rem;font-weight:600;letter-spacing:.04em;}
.pulse{width:6px;height:6px;background:var(--accent);border-radius:50%;animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.35;transform:scale(.7)}}
.hero h1{font-family:var(--font-d);font-size:clamp(2.2rem,5.5vw,3.8rem);font-weight:800;
  line-height:1.06;letter-spacing:-.03em;margin-bottom:1.1rem;}
.hero h1 .hl{background:linear-gradient(135deg,var(--accent2),var(--teal));-webkit-background-clip:text;
  -webkit-text-fill-color:transparent;background-clip:text;}
.hero p{font-size:.96rem;color:var(--text2);line-height:1.75;max-width:520px;margin:0 auto 2rem;}
.hs{position:relative;max-width:560px;margin:0 auto 1rem;}
.hs input{width:100%;background:var(--card);border:1px solid var(--border2);border-radius:13px;
  padding:.88rem 1.2rem;padding-right:6.2rem;color:var(--text);font-family:var(--font-b);font-size:.92rem;
  outline:none;box-shadow:var(--glow);transition:border .2s;}
.hs input:focus{border-color:var(--accent);}
.hs input::placeholder{color:var(--text3);}
.hs-btn{position:absolute;right:7px;top:50%;transform:translateY(-50%);background:linear-gradient(135deg,var(--accent),#8b83ff);
  color:#fff;border:none;border-radius:9px;padding:.5rem 1rem;font-size:.8rem;font-family:var(--font-b);
  font-weight:700;cursor:pointer;transition:all .18s;}
.hs-btn:hover{transform:translateY(calc(-50% - 1px));}
.chips{display:flex;gap:.4rem;flex-wrap:wrap;justify-content:center;}
.chip{font-size:.74rem;padding:.25rem .7rem;border-radius:999px;border:1px solid var(--border2);
  color:var(--text2);cursor:pointer;transition:all .18s;background:transparent;font-family:var(--font-b);}
.chip:hover{background:rgba(108,99,255,0.1);border-color:var(--accent);color:var(--accent2);}

.stat-row{display:grid;grid-template-columns:repeat(5,1fr);max-width:860px;margin:2.25rem auto 0;
  background:var(--card);border:1px solid var(--border);border-radius:var(--r2);overflow:hidden;}
.stat-cell{padding:1.1rem .75rem;text-align:center;border-right:1px solid var(--border);}
.stat-cell:last-child{border-right:none;}
.stat-n{font-family:var(--font-d);font-size:1.8rem;font-weight:800;color:var(--accent2);}
.stat-l{font-size:.65rem;color:var(--text3);margin-top:.15rem;text-transform:uppercase;letter-spacing:.08em;font-weight:600;}

.hgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:.75rem;
  padding:1.75rem 1.25rem;max-width:1050px;margin:0 auto;}
.hcard{background:var(--card);border:1px solid var(--border);border-radius:var(--r2);
  padding:1.25rem;cursor:pointer;transition:all .22s;}
.hcard:hover{border-color:var(--accent);background:var(--card2);transform:translateY(-2px);box-shadow:var(--glow);}
.hc-ico{width:38px;height:38px;border-radius:9px;display:flex;align-items:center;justify-content:center;
  font-size:1.2rem;margin-bottom:.75rem;}
.hcard h3{font-family:var(--font-d);font-size:.9rem;font-weight:700;margin-bottom:.3rem;}
.hcard p{font-size:.77rem;color:var(--text2);line-height:1.55;}

/* COLLEGES */
.col-pg{padding:1.5rem 1.25rem;max-width:1280px;margin:0 auto;}
.ph h2{font-family:var(--font-d);font-size:1.7rem;font-weight:800;}
.ph p{color:var(--text2);font-size:.85rem;margin-top:.15rem;}
.filters{display:flex;gap:.55rem;margin-top:1rem;flex-wrap:wrap;align-items:center;}
.filters input,.filters select{background:var(--card);border:1px solid var(--border2);border-radius:8px;
  padding:.52rem .85rem;color:var(--text);font-family:var(--font-b);font-size:.8rem;outline:none;transition:border .18s;}
.filters input{flex:1;min-width:180px;}
.filters input:focus,.filters select:focus{border-color:var(--accent);}
.filters select option{background:var(--bg2);}
.rcount{font-size:.75rem;color:var(--text3);margin-left:auto;}

/* SOURCE TOGGLE */
.src-toggle{display:flex;gap:.4rem;margin-top:.85rem;flex-wrap:wrap;}
.src-btn{font-size:.73rem;padding:.28rem .75rem;border-radius:999px;cursor:pointer;font-family:var(--font-b);
  font-weight:600;transition:all .18s;border:1px solid var(--border2);background:transparent;color:var(--text3);}
.src-btn.on{background:rgba(108,99,255,0.12);border-color:var(--accent);color:var(--accent2);}
.src-btn:hover{border-color:var(--accent2);color:var(--accent2);}

.cgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:.9rem;margin-top:1rem;}
/* COLLEGE CARD */
.cc{background:var(--card);border:1px solid var(--border);border-radius:var(--r2);
  display:flex;flex-direction:column;position:relative;overflow:hidden;transition:all .24s;}
.cc::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--accent),var(--teal));transform:scaleX(0);transform-origin:left;transition:transform .3s;}
.cc:hover{border-color:rgba(108,99,255,.35);transform:translateY(-3px);box-shadow:0 10px 35px rgba(0,0,0,.5),var(--glow);}
.cc:hover::before{transform:scaleX(1);}
.cc-head{display:flex;align-items:center;gap:.8rem;padding:1rem 1.1rem .8rem;border-bottom:1px solid var(--border);}
.cc-logo{width:48px;height:48px;border-radius:13px;flex-shrink:0;display:flex;align-items:center;justify-content:center;
  font-family:var(--font-d);font-weight:800;color:#fff;position:relative;overflow:hidden;
  box-shadow:0 4px 12px rgba(0,0,0,.4);letter-spacing:-.02em;}
.cc-logo::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.15) 0%,transparent 60%);}
.cc-flag{position:absolute;bottom:-1px;right:-1px;width:16px;height:16px;border-radius:50%;
  background:var(--bg2);border:1.5px solid var(--card);display:flex;align-items:center;justify-content:center;
  font-size:.55rem;z-index:2;}
.cc-info{flex:1;min-width:0;}
.cc-name{font-family:var(--font-d);font-size:.88rem;font-weight:700;line-height:1.25;
  display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
.cc-sub{font-size:.62rem;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:var(--text3);margin:.12rem 0;}
.cc-loc{font-size:.7rem;color:var(--text3);}
.cc-rank-box{flex-shrink:0;background:rgba(245,200,66,.07);border:1px solid rgba(245,200,66,.18);
  border-radius:8px;padding:.3rem .55rem;text-align:center;min-width:50px;}
.cc-rank-l{font-size:.52rem;color:var(--text3);text-transform:uppercase;letter-spacing:.07em;font-weight:700;}
.cc-rank-n{font-family:var(--font-d);font-size:1.1rem;font-weight:800;color:var(--gold2);line-height:1.1;}
.nirf-src{font-size:.48rem;color:var(--text3);margin-top:1px;}
.cc-body{padding:.8rem 1.1rem;flex:1;display:flex;flex-direction:column;gap:.6rem;}
.cc-badges{display:flex;gap:.3rem;flex-wrap:wrap;align-items:center;}
.badge{font-size:.6rem;padding:.18rem .5rem;border-radius:999px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;}
.b-iit{background:rgba(245,200,66,.1);color:var(--gold2);border:1px solid rgba(245,200,66,.22);}
.b-nit{background:rgba(34,211,184,.1);color:var(--teal);border:1px solid rgba(34,211,184,.22);}
.b-iim{background:rgba(255,107,107,.1);color:var(--coral);border:1px solid rgba(255,107,107,.22);}
.b-isc{background:rgba(139,90,43,.25);color:#cd8545;border:1px solid rgba(205,133,63,.3);}
.b-isr{background:rgba(40,83,211,.2);color:#7fa8ff;border:1px solid rgba(40,83,211,.3);}
.b-pri{background:rgba(192,132,252,.1);color:var(--violet);border:1px solid rgba(192,132,252,.22);}
.b-pub{background:rgba(34,211,184,.1);color:var(--teal);border:1px solid rgba(34,211,184,.22);}
.b-med{background:rgba(255,107,107,.1);color:var(--coral);border:1px solid rgba(255,107,107,.22);}
.b-tec{background:rgba(34,197,94,.1);color:var(--green);border:1px solid rgba(34,197,94,.22);}
.b-col{background:rgba(108,99,255,.1);color:var(--accent2);border:1px solid rgba(108,99,255,.22);}
.b-uni{background:rgba(0,150,200,.12);color:#52c8e8;border:1px solid rgba(0,150,200,.25);}
.b-wom{background:rgba(240,68,160,.1);color:#f478c8;border:1px solid rgba(240,68,160,.22);}
.b-law{background:rgba(34,197,94,.1);color:var(--green);border:1px solid rgba(34,197,94,.22);}
.b-mgm{background:rgba(255,200,50,.1);color:var(--gold);border:1px solid rgba(255,200,50,.22);}
.star-pill{display:flex;align-items:center;gap:.2rem;background:rgba(245,200,66,.08);
  border:1px solid rgba(245,200,66,.18);border-radius:999px;padding:.13rem .45rem;font-size:.67rem;font-weight:700;color:var(--gold2);}
.cc-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:.35rem;}
.cs{background:var(--bg3);border-radius:7px;padding:.42rem .5rem;}
.cs-l{font-size:.56rem;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:2px;font-weight:700;}
.cs-v{font-size:.8rem;font-weight:700;color:var(--text);}
.cs-v.g{color:var(--green);}
.cs-v.gl{color:var(--gold2);}
.cc-foot{display:flex;gap:.35rem;padding:.7rem 1.1rem;border-top:1px solid var(--border);background:rgba(0,0,0,.12);}
.cc-btn{flex:1;padding:.38rem .2rem;border-radius:7px;font-size:.7rem;cursor:pointer;font-family:var(--font-b);
  font-weight:600;transition:all .18s;border:1px solid var(--border2);background:transparent;color:var(--text2);}
.cc-btn:hover{background:var(--bg3);color:var(--text);}
.cc-btn.sv{background:rgba(108,99,255,.1);color:var(--accent2);border-color:rgba(108,99,255,.28);}
.cc-btn.cp{background:rgba(34,211,184,.08);color:var(--teal);border-color:rgba(34,211,184,.28);}

/* PREDICTOR */
.pred-pg{padding:1.75rem 1.25rem;max-width:980px;margin:0 auto;}
.pred-pg h2{font-family:var(--font-d);font-size:1.7rem;font-weight:800;margin-bottom:.25rem;}
.pred-pg>.desc{color:var(--text2);font-size:.86rem;margin-bottom:1.75rem;}
.pred-form{background:var(--card);border:1px solid var(--border);border-radius:var(--r2);
  padding:1.5rem;display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:.9rem;
  margin-bottom:1.5rem;position:relative;overflow:hidden;}
.pred-form::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--accent),var(--teal),var(--violet));}
.fg{display:flex;flex-direction:column;gap:.3rem;}
.fg label{font-size:.67rem;font-weight:700;color:var(--text2);text-transform:uppercase;letter-spacing:.07em;}
.fg input,.fg select{background:var(--bg3);border:1px solid var(--border2);border-radius:8px;
  padding:.62rem .85rem;color:var(--text);font-family:var(--font-b);font-size:.85rem;outline:none;transition:border .18s;}
.fg input:focus,.fg select:focus{border-color:var(--accent);}
.fg select option{background:var(--bg2);}
.fg small{font-size:.64rem;color:var(--text3);margin-top:.1rem;}
.pred-sub{grid-column:1/-1;}
.pred-res-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:.85rem;}
.pred-res-hd h3{font-family:var(--font-d);font-size:1.05rem;font-weight:700;}
.mtag{font-size:.7rem;padding:.22rem .65rem;border-radius:999px;background:rgba(34,211,184,.1);
  color:var(--teal);border:1px solid rgba(34,211,184,.25);font-weight:700;}
.pred-cards{display:flex;flex-direction:column;gap:.65rem;}
.pc{background:var(--card);border:1px solid var(--border);border-radius:var(--r2);
  padding:.9rem 1.1rem;display:flex;justify-content:space-between;align-items:center;gap:.85rem;cursor:pointer;transition:all .2s;}
.pc:hover{border-color:var(--accent);transform:translateX(3px);}
.pc-l{display:flex;align-items:center;gap:.75rem;min-width:0;flex:1;}
.pc-logo{width:40px;height:40px;border-radius:10px;flex-shrink:0;display:flex;align-items:center;justify-content:center;
  font-family:var(--font-d);font-weight:800;color:#fff;position:relative;overflow:hidden;}
.pc-logo::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.15),transparent);}
.pc-name{font-weight:700;font-size:.87rem;line-height:1.3;}
.pc-meta{font-size:.7rem;color:var(--text3);margin-top:.12rem;}
.pc-r{display:flex;align-items:center;gap:.65rem;flex-shrink:0;}
.pc-pct{text-align:center;}
.pc-pct-n{font-family:var(--font-d);font-size:1.35rem;font-weight:800;line-height:1;}
.pc-pct-l{font-size:.6rem;color:var(--text3);text-transform:uppercase;letter-spacing:.05em;margin-top:1px;}
.chance{font-size:.67rem;font-weight:700;padding:.22rem .6rem;border-radius:999px;text-transform:uppercase;letter-spacing:.05em;}
.ch-h{background:rgba(34,197,94,.12);color:var(--green);border:1px solid rgba(34,197,94,.25);}
.ch-m{background:rgba(245,200,66,.12);color:var(--gold2);border:1px solid rgba(245,200,66,.25);}
.ch-l{background:rgba(255,107,107,.1);color:var(--coral);border:1px solid rgba(255,107,107,.22);}
.pc-meter{height:3px;background:var(--bg3);border-radius:2px;margin-top:.55rem;overflow:hidden;}
.pc-mf{height:100%;border-radius:2px;background:linear-gradient(90deg,var(--accent),var(--teal));transition:width .8s ease;}

/* CHATBOT */
.chat-pg{display:grid;grid-template-columns:270px 1fr;gap:.85rem;height:calc(100vh - 58px);
  padding:.85rem 1.25rem;max-width:1250px;margin:0 auto;}
.chat-sb{background:var(--card);border:1px solid var(--border);border-radius:var(--r2);
  display:flex;flex-direction:column;overflow:hidden;}
.sb-head{padding:.95rem 1rem;border-bottom:1px solid var(--border);flex-shrink:0;}
.sb-head h3{font-family:var(--font-d);font-size:.9rem;font-weight:700;margin-bottom:.55rem;}
.pf-fields{display:flex;flex-direction:column;gap:.45rem;}
.pf{display:flex;flex-direction:column;gap:.25rem;}
.pf label{font-size:.6rem;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.07em;}
.pf input,.pf select{background:var(--bg3);border:1px solid var(--border);border-radius:7px;
  padding:.45rem .65rem;color:var(--text);font-family:var(--font-b);font-size:.77rem;outline:none;transition:border .18s;}
.pf input:focus,.pf select:focus{border-color:var(--accent);}
.pf select option{background:var(--bg2);}
.sp-btn{width:100%;margin-top:.55rem;padding:.55rem;background:linear-gradient(135deg,var(--accent),#8b83ff);
  color:#fff;border:none;border-radius:8px;font-family:var(--font-b);font-size:.77rem;font-weight:700;
  cursor:pointer;transition:all .18s;}
.sp-btn:hover{transform:translateY(-1px);box-shadow:0 4px 14px rgba(108,99,255,.35);}
.sb-topics{padding:.75rem 1rem;border-top:1px solid var(--border);overflow-y:auto;flex:1;}
.sb-topics p{font-size:.62rem;color:var(--text3);text-transform:uppercase;letter-spacing:.07em;font-weight:700;margin-bottom:.5rem;}
.t-btn{display:block;width:100%;text-align:left;background:var(--bg3);border:1px solid var(--border);
  border-radius:7px;padding:.42rem .65rem;color:var(--text2);font-family:var(--font-b);font-size:.73rem;
  cursor:pointer;transition:all .18s;margin-bottom:.35rem;}
.t-btn:hover{border-color:var(--accent);color:var(--accent2);background:rgba(108,99,255,.08);}

.chat-main{background:var(--card);border:1px solid var(--border);border-radius:var(--r2);
  display:flex;flex-direction:column;overflow:hidden;}
.chat-topbar{display:flex;align-items:center;gap:.65rem;padding:.75rem 1.1rem;
  border-bottom:1px solid var(--border);background:rgba(0,0,0,.15);}
.bot-av{width:34px;height:34px;border-radius:9px;background:linear-gradient(135deg,var(--accent),var(--teal));
  display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;}
.bot-nm{font-family:var(--font-d);font-size:.85rem;font-weight:700;}
.bot-st{display:flex;align-items:center;gap:.3rem;font-size:.67rem;color:var(--green);}
.bot-st::before{content:'';width:5px;height:5px;background:var(--green);border-radius:50%;animation:pulse 2s infinite;}
.clr-btn{font-size:.7rem;color:var(--text3);background:none;border:1px solid var(--border);border-radius:6px;
