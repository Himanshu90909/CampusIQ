    const intent=detectIntent(txt);
    const ent=extractEntities(txt);
    const resp=genResp(txt,ent,intent);
    const botText=typeof resp==='string'?resp:resp.text;
    const cards=(typeof resp==='object'&&resp.cards)||[];
    addMsg('bot',botText,cards);
    chatHist.push({role:'bot',content:botText});
    busy=false;
    document.getElementById('sendBtn').disabled=false;
  },delay);
}

function clearChat(){
  document.getElementById('chatMsgs').innerHTML='';
  chatHist=[];chatInit=false;initChat();
}
function askT(q){document.getElementById('chatIn').value=q;sendMsg();}
function askS(el){document.getElementById('chatIn').value=el.textContent;sendMsg();}

// ── SAVE / COMPARE ──
function toggleSv(id,btn){
  const idx=saveList.indexOf(id);
  if(idx>-1){saveList.splice(idx,1);toast('Removed','inf');}
  else{saveList.push(id);toast('Saved ❤️','ok');}
  localStorage.setItem('ciq_sv',JSON.stringify(saveList));
  if(btn){btn.textContent=saveList.includes(id)?'❤️ Save':'🤍 Save';btn.classList.toggle('sv',saveList.includes(id));}
}

function toggleCp(id,btn){
  const col=DB.find(c=>c.id===id);if(!col) return;
  const idx=cmpList.findIndex(c=>c.id===id);
  if(idx>-1){cmpList.splice(idx,1);toast('Removed from compare','inf');}
  else{if(cmpList.length>=3){toast('Max 3 colleges','inf');return;}cmpList.push(col);toast(col.abbr+' added ⚖️','ok');}
  updCmpF();
  if(btn){btn.textContent=cmpList.find(c=>c.id===id)?'✓ Cmp':'+ Cmp';btn.classList.toggle('cp',!!cmpList.find(c=>c.id===id));}
}
function clearCmp(){cmpList=[];updCmpF();toast('Cleared','inf');if(pg==='compare')renderCmp();if(pg==='colleges')renderCols();}
function updCmpF(){document.getElementById('cmpCnt').textContent=cmpList.length;document.getElementById('cmpf').classList.toggle('vis',cmpList.length>0);}

// ── COMPARE RENDER ──
function renderCmp(){
  const el=document.getElementById('cmpSlots');
  const slots=[];
  for(let i=0;i<3;i++){
    const c=cmpList[i];
    if(c){
      const [g1,g2]=c.grad,t=c.abbr||'';
      const bN=(f,lo=false)=>{if(cmpList.length<2) return '';const vs=cmpList.map(x=>x[f]||0);const tg=lo?Math.min(...vs):Math.max(...vs);return (c[f]||0)===tg?'cmp-best':'';}
      const bP=()=>{if(cmpList.length<2)return '';const vs=cmpList.map(x=>x.placements.rate);const tg=Math.max(...vs);return c.placements.rate===tg?'cmp-best':'';}
      const rk=c.source==='nirf2025college'?`NIRF 2025 College #${c.nirf2025college}`:`NIRF 2020 #${c.nirf2020}`;
      slots.push(`<div class="cmp-slot">
        <div class="cmp-h">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:.65rem">
            <div style="width:42px;height:42px;border-radius:11px;background:linear-gradient(145deg,${g1},${g2});display:flex;align-items:center;justify-content:center;font-family:var(--font-d);font-weight:800;font-size:${t.length<=3?'.82rem':'.65rem'};color:#fff;position:relative;overflow:hidden">
              ${escH(t)}<div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.15),transparent)"></div>
            </div>
            <button class="btn btn-ghost btn-sm" onclick="cmpList.splice(${i},1);renderCmp();updCmpF()">✕</button>
          </div>
          <div style="font-family:var(--font-d);font-size:.85rem;font-weight:700;line-height:1.3">${escH(c.name)}</div>
          <div style="font-size:.7rem;color:var(--text3);margin-top:.22rem">${escH(c.state)}</div>
          <div style="font-size:.65rem;color:var(--accent2);margin-top:.15rem">${rk}</div>
        </div>
        <div class="cmp-attr"><div class="cmp-k">NIRF Overall Score</div><div class="cmp-v ${bN('nirfScore')}" style="color:var(--gold2)">${c.nirfScore}</div></div>
        <div class="cmp-attr"><div class="cmp-k">TLR (Teaching & Learning)</div><div class="cmp-v ${bN('tlr')}">${c.tlr||'—'}</div></div>
        <div class="cmp-attr"><div class="cmp-k">RPC (Research)</div><div class="cmp-v ${bN('rpc')}">${c.rpc||'—'}</div></div>
        <div class="cmp-attr"><div class="cmp-k">GO (Grad Outcomes)</div><div class="cmp-v ${bN('go')}">${c.go||'—'}</div></div>
        <div class="cmp-attr"><div class="cmp-k">OI (Inclusivity)</div><div class="cmp-v ${bN('oi')}">${c.oi||'—'}</div></div>
        <div class="cmp-attr"><div class="cmp-k">Perception</div><div class="cmp-v ${bN('perception')}">${c.perception||'—'}</div></div>
        <div class="cmp-attr"><div class="cmp-k">Annual Fees</div><div class="cmp-v ${bN('fees',true)}">${fmtFee(c)}</div></div>
        <div class="cmp-attr"><div class="cmp-k">Avg Salary</div><div class="cmp-v ${bN('salary')}">${fmtSal(c)}</div></div>
        <div class="cmp-attr"><div class="cmp-k">Placement Rate</div><div class="cmp-v ${bP()}">${c.placements.rate}%</div></div>
        <div class="cmp-attr"><div class="cmp-k">Type</div><div class="cmp-v"><span class="badge ${bc(c.type)}">${escH(c.type)}</span></div></div>
        <div class="cmp-attr"><div style="margin-top:.2rem"><button class="btn btn-pri btn-sm" style="width:100%" onclick="openDet(${c.id})">Full Details</button></div></div>
      </div>`);
    } else {
      slots.push(`<div class="cmp-slot empty"><div style="text-align:center;color:var(--text3);padding:1.5rem">
        <div style="font-size:2rem;opacity:.18">⚖️</div>
        <p style="font-size:.8rem;margin-top:.45rem;line-height:1.5">Add a college<br>from the directory</p>
        <button class="btn btn-ghost btn-sm" style="margin-top:.55rem" onclick="goto('colleges')">Browse →</button>
      </div></div>`);
    }
  }
  el.innerHTML=slots.join('');
  document.getElementById('cmpNote').textContent=cmpList.length<2?'Add at least 2 institutions. 💚 Green = best NIRF parameter across selected colleges.':'💚 Green = best value in each NIRF parameter across your selection.';
}

// ── TOAST ──
function toast(msg,type='inf'){
  const t=document.getElementById('toast');
  t.textContent=msg;t.className='toast show '+type;
  setTimeout(()=>t.classList.remove('show'),2800);
}

// ── INIT ──
renderCols();
updateHint();
</script>
